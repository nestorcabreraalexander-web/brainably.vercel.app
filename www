  document.getElementById('ans-locked').style.display='none';
}

// ════════════ FORMAT ANSWER ════════════
function fmtAnswer(text) {
  const lines=text.split('\n');
  let html='', stepTitle='', stepLines=[];
  function flush(){
    if(!stepTitle) return;
    html+=`<div class="step-card"><div class="step-num">${stepTitle}</div><div class="step-text">${stepLines.join('<br>').trim()}</div></div>`;
    stepTitle=''; stepLines=[];
  }
  for(const line of lines){
    const t=line.trim(); if(!t){ if(stepTitle) stepLines.push(''); continue; }
    if(/^(✅|⭐|🎯)?\s*(Answer|Final Answer|Key Takeaway|Result)\s*[:–—]/i.test(t)||/^✅\s+\S/.test(t)){
      flush();
      const val=t.replace(/^(✅|⭐|🎯)?\s*(Answer|Final Answer|Key Takeaway|Result)\s*[:–—]\s*/i,'').replace(/^✅\s*/,'');
      html+=`<div class="answer-final"><div class="answer-label">✅ Answer</div><div class="answer-value">${val||t}</div></div>`;
    } else if(/^Step\s*\d+\s*[:–—.]/i.test(t)||/^\d+[.)]\s+[A-Z]/i.test(t)){
      flush(); stepTitle=t;
    } else {
      if(stepTitle) stepLines.push(t);
      else html+=`<p style="margin-bottom:7px;line-height:1.75;font-size:.91rem;font-weight:600">${t}</p>`;
    }
  }
  flush();
  return html||`<p style="line-height:1.85;font-size:.91rem;font-weight:600;white-space:pre-wrap">${text}</p>`;
}

