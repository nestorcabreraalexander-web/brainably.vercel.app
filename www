async function rephrase(){
  if(!curQuestion) return;
  const btn=document.getElementById('rephrase-btn'); btn.disabled=true; btn.textContent='⏳...';
  const sys=`You are StudyBuddy. The student is ${getGrade()} and didn't understand the first explanation. Use a completely different approach — real-life analogy, simpler words, new angle. Use the same Step 1/Step 2/✅ Answer format. Subject: ${subject}`;
  try {
    const ans=await callAI(sys,`Please explain this differently: "${curQuestion}"`);
    curAnswer=ans;
    document.getElementById('ans-content').innerHTML=
      `<div style="background:var(--yellow);border-radius:11px;padding:9px 13px;margin-bottom:11px;font-size:.82rem;font-weight:800;color:#92400E">🔁 Here's a different explanation!</div>`+fmtAnswer(ans);
    if(answerMode==='hide'){ document.querySelectorAll('.answer-final').forEach(e=>e.style.display='none'); document.getElementById('ans-locked').style.display='block'; }
  } catch(e){ toast('⚠️ Could not rephrase'); }
  btn.disabled=false; btn.innerHTML='🔁 Explain differently';
}

// ════════════ QUIZ ════════════
async function startQuiz(){
  const qw=document.getElementById('quiz-wrap'); qw.classList.add('show');
  const ql=document.getElementById('quiz-load'); ql.style.display='flex';
  document.getElementById('quiz-body').innerHTML='';
  const sys=`You are a quiz generator. Respond ONLY with valid JSON, no markdown.\n{"questions":[{"q":"...","options":["A","B","C","D"],"answer":0,"explanation":"..."},...]} — 3 questions, answer is 0-based index. Grade: ${getGrade()}`;
  try {
    const raw=await callAI(sys,`Topic: ${curQuestion}\nContent: ${curAnswer.slice(0,500)}`);
    quizData=JSON.parse(raw.replace(/```json|```/g,'').trim());
    quizIdx=0; ql.style.display='none'; renderQuizQ();
    quizTaken=true;
    if(history[0]) { history[0].quizTaken=true; localStorage.setItem('sb_history',JSON.stringify(history.slice(0,40))); }
    // Unlock answer after quiz if in 'hide' mode
    if(answerMode==='hide'){ document.querySelectorAll('.answer-final').forEach(e=>e.style.display='block'); document.getElementById('ans-locked').style.display='none'; }
  } catch(e){ ql.style.display='none'; document.getElementById('quiz-body').innerHTML=`<div class="error-box">⚠️ Couldn't generate quiz.</div>`; }
}

function renderQuizQ(){
  const qb=document.getElementById('quiz-body');
  if(!quizData||quizIdx>=quizData.questions.length){
    qb.innerHTML=`<div style="text-align:center;padding:14px 0"><div style="font-size:1.8rem;margin-bottom:6px">🎉</div><div style="font-weight:800">Quiz complete! Great work.</div></div>`; return;
  }
  const q=quizData.questions[quizIdx], tot=quizData.questions.length;
  qb.innerHTML=`<div style="font-size:.7rem;font-weight:800;color:var(--muted);margin-bottom:6px">Question ${quizIdx+1} of ${tot}</div>
    <div class="quiz-q">${q.q}</div>
    <div class="quiz-opts">${q.options.map((o,i)=>`<button class="quiz-opt" onclick="answerQ(${i})">${o}</button>`).join('')}</div>
    <div class="quiz-fb" id="qfb"></div>
    <button class="next-btn" id="nxt-btn" onclick="nextQ()">${quizIdx+1<tot?'Next →':'Finish ✓'}</button>`;
}
function answerQ(chosen){
  const q=quizData.questions[quizIdx];
  document.querySelectorAll('.quiz-opt').forEach(o=>o.disabled=true);
  document.querySelectorAll('.quiz-opt')[q.answer].classList.add('correct');
  if(chosen!==q.answer) document.querySelectorAll('.quiz-opt')[chosen].classList.add('wrong');
  const fb=document.getElementById('qfb'); fb.className='quiz-fb show '+(chosen===q.answer?'correct':'wrong');
  fb.textContent=chosen===q.answer?`✅ Correct! ${q.explanation}`:`❌ The answer is: "${q.options[q.answer]}". ${q.explanation}`;
  document.getElementById('nxt-btn').classList.add('show');
}
function nextQ(){ quizIdx++; renderQuizQ(); }

