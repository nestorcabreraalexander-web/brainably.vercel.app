          <div class="action-btns">
            <button class="act-btn yellow" id="rephrase-btn" onclick="rephrase()">🔁 Explain differently</button>
            <button class="act-btn purple" id="quiz-btn" onclick="startQuiz()">🧪 Quiz me</button>
          </div>
          <div class="quiz-wrap" id="quiz-wrap">
            <div class="quiz-card">
              <div class="quiz-meta">🧪 Quick Quiz</div>
              <div id="quiz-load" class="loading" style="display:none"><div class="dot"></div><div class="dot"></div><div class="dot"></div><span>Making quiz...</span></div>
              <div id="quiz-body"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Examples -->
    <div class="card">
      <div class="card-title">💬 Try an example</div>
      <div style="display:flex;flex-wrap:wrap;gap:7px">
        <button class="sub-btn" onclick="tryEx('Find the average of: 11 inches, 12 inches, 11 inches, 12 inches','Math')">Average of lengths</button>
        <button class="sub-btn" onclick="tryEx('Solve for x: 3x + 7 = 22','Math')">3x + 7 = 22</button>
        <button class="sub-btn" onclick="tryEx('What is the difference between a simile and a metaphor?','Grammar')">Simile vs Metaphor</button>
        <button class="sub-btn" onclick="tryEx('How does photosynthesis work?','Science')">Photosynthesis</button>
        <button class="sub-btn" onclick="tryEx('What were the main causes of World War I?','History')">WWI Causes</button>
        <button class="sub-btn" onclick="tryEx('What is the Pythagorean theorem?','Math')">Pythagorean Theorem</button>
      </div>
    </div>
  </div>
</div>

