}

async function fetchExplanation(attempt='') {
  setBusy(true);

  const sys = `You are StudyBuddy, a patient and encouraging AI tutor. The student is ${getGrade()}.
ALWAYS format your response with clear numbered steps using EXACTLY this pattern:
Step 1: [Short title]
[Explanation on the next line(s)]
Step 2: [Short title]
[Explanation]
...
✅ Answer: [The final answer or key takeaway]

For any math problem: show the formula, the substitution, and the arithmetic separately.
Use language appropriate for their grade level. Be warm and encouraging.
Subject: ${subject}

Example for "average of 11,12,11,12 inches":
Step 1: Understand what average means
Average (mean) = total sum ÷ number of values.
Step 2: Add all the values
11 + 12 + 11 + 12 = 46 inches
Step 3: Divide by the count
There are 4 values, so 46 ÷ 4 = 11.5
✅ Answer: The average length is 11.5 inches`;

  const usr = attempt
    ? `Question: ${curQuestion}\n\nThe student attempted: "${attempt}"\nAcknowledge their attempt briefly, then give the full step-by-step explanation.`
    : curQuestion;

  try {
    const ans = await callAI(sys, usr);
    curAnswer = ans;
    setBusy(false);
    document.getElementById('ans-content').innerHTML = fmtAnswer(ans);
    document.getElementById('ans-area').classList.add('visible');
    showVidLinks(curQuestion, subject);

    // Answer locking
    if(answerMode === 'hide') {
      // hide the answer-final div
      document.querySelectorAll('.answer-final').forEach(el=>el.style.display='none');
      document.getElementById('ans-locked').style.display='block';
    } else {
      document.getElementById('ans-locked').style.display='none';
    }

    // Save history
    history.unshift({ subject, question:curQuestion, timestamp:Date.now(), quizTaken:false, attempt:attempt||null });
    localStorage.setItem('sb_history',JSON.stringify(history.slice(0,40)));

    // Reset quiz UI
    document.getElementById('quiz-wrap').classList.remove('show');
    document.getElementById('quiz-body').innerHTML='';
    quizData=null;

  } catch(e) {
    setBusy(false);
    document.getElementById('err-msg').textContent='⚠️ '+e.message;
    document.getElementById('err-st').style.display='block';
  }
}

function setBusy(on) {
  const btn=document.getElementById('solve-btn');
  btn.disabled=on; btn.innerHTML=on?'⏳ Thinking...':'🚀 Explain it to me';
  document.getElementById('empty-st').style.display='none';
  document.getElementById('err-st').style.display='none';
  document.getElementById('ans-area').classList.remove('visible');
  document.getElementById('load-st').style.display=on?'block':'none';
  if(on) document.getElementById('vid-links').style.display='none';
}

function unlockAnswer() {
