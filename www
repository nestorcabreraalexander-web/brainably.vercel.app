<script>
// ════════════ STATE ════════════
let subject = 'Math';
let curQuestion = '', curAnswer = '';
let learningMode = false;
let answerMode = 'attempt'; // 'attempt' | 'always' | 'hide'
let quizData = null, quizIdx = 0;
let quizTaken = false;
let history = JSON.parse(localStorage.getItem('sb_history')||'[]');
let tasks   = JSON.parse(localStorage.getItem('sb_tasks')||'{}');
let schoolColor = localStorage.getItem('sb_color')||'#3B82F6';
let schoolColorDark = localStorage.getItem('sb_color_dark')||'#1D4ED8';
let teacherPin = localStorage.getItem('sb_pin')||'1234';

// ════════════ INIT ════════════
function init() {
  loadGrade();
  applyColor(schoolColor, schoolColorDark, false);
  const sn = localStorage.getItem('sb_school_name');
  if (sn) applySchoolName(sn, false);
  const lm = localStorage.getItem('sb_lm');
  if (lm === 'true') { learningMode = true; document.getElementById('lm-track').classList.add('on'); }
  else { learningMode = false; localStorage.setItem('sb_lm', 'false'); }
  const am = localStorage.getItem('sb_answer_mode');
  if (am) answerMode = am;
  renderVideos('All');
  // mark active swatch
  document.querySelectorAll('.color-swatch').forEach(s => {
    s.classList.toggle('active', s.dataset.color === schoolColor);
  });
  // live preview update
  document.getElementById('school-name-input').addEventListener('input', updatePreview);
  document.getElementById('q-input').addEventListener('keydown', e => { if(e.key==='Enter'&&e.ctrlKey) solveQ(); });
}

// ════════════ NAV ════════════
function showPage(id, btn) {
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('nav button').forEach(b=>b.classList.remove('active'));
  document.getElementById('page-'+id).classList.add('active');
  if(btn) btn.classList.add('active');
  if(id==='progress')  renderProgress();
  if(id==='dashboard') renderDashboard();
  if(id==='teacher')   renderTeacher();
  if(id==='videos')    renderVideos('All');
}
function goHelper(s) { selSubj(s,null); showPage('helper',document.querySelectorAll('nav button')[1]); }

// ════════════ GRADE ════════════
function loadGrade() { const g=localStorage.getItem('sb_grade'); if(g) document.getElementById('grade-sel').value=g; }
function saveGrade() { localStorage.setItem('sb_grade',document.getElementById('grade-sel').value); toast('Grade level saved!'); }
function getGrade() {
  const m={elementary:'an elementary school student (grades K-5)',middle:'a middle school student (grades 6-8)',high:'a high school student (grades 9-12)',college:'a college student'};
  return m[document.getElementById('grade-sel').value]||m.middle;
}

// ════════════ LEARNING MODE ════════════
function toggleLearningMode() {
  learningMode = !learningMode;
  document.getElementById('lm-track').classList.toggle('on', learningMode);
  localStorage.setItem('sb_lm', learningMode);
  const banner = document.getElementById('lm-banner');
  banner.style.display = learningMode ? 'flex' : 'none';
  toast(learningMode ? '🔒 Learning Mode ON' : '🔓 Learning Mode OFF');
}

// ════════════ SUBJECT ════════════
function selSubj(s, el) {
  subject = s;
  document.querySelectorAll('.sub-btn').forEach(b=>b.classList.remove('sel'));
  if(el) el.classList.add('sel');
  else document.querySelectorAll('#subj-row .sub-btn').forEach(b=>{ if(b.textContent.toLowerCase().includes(s.toLowerCase())) b.classList.add('sel'); });
}

// ════════════ EXAMPLES ════════════
function tryEx(q,s) { selSubj(s,null); document.getElementById('q-input').value=q; solveQ(); }

// ════════════ AI ════════════
async function callAI(sys, usr, maxTok=950) {
  const key = localStorage.getItem('sb_openrouter_key') || '';
  if(!key) { toast('⚠️ No API key — go to School Setup to add your free key!'); throw new Error('No API key'); }
  const r = await fetch('https://openrouter.ai/api/v1/chat/completions', {
    method:'POST',
    headers:{'Content-Type':'application/json','Authorization':'Bearer '+key,'HTTP-Referer':'https://studybuddy-2.vercel.app','X-Title':'StudyBuddy'},
    body: JSON.stringify({
      model: 'openrouter/free',
      max_tokens: maxTok,
      messages: [
        {role:'system', content: sys},
        {role:'user', content: usr}
      ]
    })
  });
  if(!r.ok){ const e=await r.json().catch(()=>({})); throw new Error(e.error?.message||'Error '+r.status); }
  const d = await r.json();
  return d.choices?.[0]?.message?.content || '';
}

// ════════════ SOLVE ════════════
async function solveQ() {
  const q = document.getElementById('q-input').value.trim();
  if(!q){ document.getElementById('q-input').focus(); return; }
  curQuestion=q; quizTaken=false;

  // Learning mode: show attempt box first
  if(learningMode && answerMode !== 'always') {
    document.getElementById('empty-st').style.display='none';
    document.getElementById('err-st').style.display='none';
    document.getElementById('ans-area').classList.remove('visible');
    document.getElementById('attempt-box').style.display='block';
    document.getElementById('attempt-input').value='';
    document.getElementById('attempt-input').focus();
    return;
  }
  await fetchExplanation();
}

function submitAttempt() {
  const attempt = document.getElementById('attempt-input').value.trim();
  if(!attempt){ document.getElementById('attempt-input').focus(); return; }
  // Log the attempt for teacher view
  history[0] && (history[0].attempt = attempt);
  document.getElementById('attempt-box').style.display='none';
  fetchExplanation(attempt);
}

function skipAttempt() {
