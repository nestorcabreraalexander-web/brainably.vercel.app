    <a class="vid-card" href="https://www.youtube.com/results?search_query=${encodeURIComponent(v.q)}" target="_blank" rel="noopener">
      <div class="vid-thumb" style="background:${v.bg}"><span>${v.icon}</span><div class="play-btn">▶</div></div>
      <div class="vid-info"><div class="vid-subj" style="color:${v.sc}">${v.s}</div><div class="vid-ttl">${v.t}</div><div class="vid-ch">🎬 ${v.ch} · Opens YouTube</div></div>
    </a>`).join('');
}
function filterVids(f,btn){
  document.querySelectorAll('.flt-btn').forEach(b=>b.classList.remove('active')); btn.classList.add('active'); renderVideos(f);
}

// ════════════ DASHBOARD ════════════
function renderDashboard(){
  const counts={};
  history.forEach(h=>counts[h.subject]=(counts[h.subject]||0)+1);
  const top=Object.keys(counts).sort((a,b)=>counts[b]-counts[a])[0]||'—';
  document.getElementById('stats-row').innerHTML=`
    <div class="stat-card"><div class="stat-num" style="color:var(--brand)">${history.length}</div><div class="stat-lbl">Questions Asked</div></div>
    <div class="stat-card"><div class="stat-num" style="font-size:1.2rem;color:var(--orange-dark)">${top}</div><div class="stat-lbl">Top Subject</div></div>
    <div class="stat-card"><div class="stat-num" style="color:var(--green-dark)">${Object.keys(tasks).length}</div><div class="stat-lbl">Plan Tasks Done</div></div>
    <div class="stat-card"><div class="stat-num" style="color:var(--purple-dark)">${history.filter(h=>h.quizTaken).length}</div><div class="stat-lbl">Quizzes Taken</div></div>`;

  const bgs={Math:'var(--purple)',Grammar:'var(--pink)',Science:'var(--green)',History:'var(--orange)',Other:'var(--brand-light)'};
  const ics={Math:'➕',Grammar:'✏️',Science:'🔬',History:'🌍',Other:'💬'};
  const ul=document.getElementById('rec-list');
  ul.innerHTML=!history.length
    ?'<li style="padding:16px 0;text-align:center;color:var(--muted);font-weight:700">No questions yet!</li>'
    :history.slice(0,8).map(h=>`<li class="rec-item">
        <div class="rec-icon" style="background:${bgs[h.subject]||bgs.Other}">${ics[h.subject]||'💬'}</div>
        <div class="rec-info"><div class="rec-title">${h.question.length>65?h.question.slice(0,62)+'…':h.question}</div>
        <div class="rec-sub">${h.subject} · ${ago(h.timestamp)}${h.quizTaken?' · ✅ Quiz taken':''}</div></div>
      </li>`).join('');
}

function ago(ts){ const s=Math.floor((Date.now()-ts)/1000); if(s<60) return 'Just now'; if(s<3600) return Math.floor(s/60)+'m ago'; return Math.floor(s/3600)+'h ago'; }

// ════════════ TOAST ════════════
function toast(msg){ const t=document.getElementById('toast'); t.textContent=msg; t.classList.add('show'); setTimeout(()=>t.classList.remove('show'),2200); }

// ════════════ OPENROUTER KEY ════════════
function saveOpenRouterKey(){
  const inp = document.getElementById('openrouter-key-inp');
  const status = document.getElementById('key-status');
  const k = inp ? inp.value.trim() : '';
  if(!k){
    if(status){ status.style.display='block'; status.style.background='#FEE2E2'; status.style.color='#DC2626'; status.textContent='❌ Please enter your key first'; }
    return;
  }
  localStorage.setItem('sb_openrouter_key', k);
  if(status){ status.style.display='block'; status.style.background='#D1FAE5'; status.style.color='#059669'; status.textContent='✅ Key saved! StudyBuddy is ready!'; }
  toast('✅ OpenRouter key saved!');
}

// ════════════ START ════════════
init();
</script>

