<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>StudyBuddy – AI Homework Helper</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Fraunces:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
<style>
  :root {
    --brand:#3B82F6; --brand-dark:#1D4ED8; --brand-light:#E8F4FD;
    --yellow:#FDE68A; --yellow-dark:#F59E0B;
    --green:#D1FAE5; --green-dark:#059669;
    --pink:#FCE7F3; --pink-dark:#DB2777;
    --purple:#EDE9FE; --purple-dark:#7C3AED;
    --orange:#FFEDD5; --orange-dark:#EA580C;
    --red:#FEE2E2; --red-dark:#DC2626;
    --bg:#F0F7FF; --text:#1E293B; --muted:#64748B;
    --white:#fff; --shadow:0 4px 20px rgba(59,130,246,.12); --r:20px;
  }
  *{margin:0;padding:0;box-sizing:border-box}
  body{font-family:'Nunito',sans-serif;background:var(--bg);color:var(--text);min-height:100vh}

  /* ── NAV ── */
  nav{background:var(--white);padding:11px 22px;display:flex;align-items:center;justify-content:space-between;box-shadow:0 2px 12px rgba(0,0,0,.07);position:sticky;top:0;z-index:300;flex-wrap:wrap;gap:8px}
  .logo{font-size:1.4rem;font-weight:900;color:var(--brand);display:flex;align-items:center;gap:7px;cursor:pointer}
  .school-name{font-size:.78rem;font-weight:800;color:var(--muted);margin-left:4px;opacity:.8}
  nav ul{list-style:none;display:flex;gap:3px;flex-wrap:wrap}
  nav ul li button{background:none;border:none;font-family:'Nunito',sans-serif;font-size:.86rem;font-weight:700;color:var(--muted);cursor:pointer;padding:6px 12px;border-radius:50px;transition:all .2s}
  nav ul li button:hover,nav ul li button.active{background:var(--brand-light);color:var(--brand)}
  .nav-right{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
  .grade-sel{border:2px solid #E2E8F0;border-radius:50px;padding:5px 10px;font-family:'Nunito',sans-serif;font-size:.8rem;font-weight:700;outline:none;cursor:pointer;background:white}
  .grade-sel:focus{border-color:var(--brand)}
  .mode-toggle{display:flex;align-items:center;gap:7px;font-size:.78rem;font-weight:800;color:var(--muted)}
  .toggle-track{width:38px;height:20px;background:#CBD5E1;border-radius:50px;cursor:pointer;position:relative;transition:background .25s;flex-shrink:0}
  .toggle-track.on{background:var(--green-dark)}
  .toggle-thumb{width:16px;height:16px;background:white;border-radius:50%;position:absolute;top:2px;left:2px;transition:left .25s;box-shadow:0 1px 4px rgba(0,0,0,.2)}
  .toggle-track.on .toggle-thumb{left:20px}

  /* ── PAGES ── */
  .page{display:none;animation:fadeIn .3s ease}
  .page.active{display:block}
  @keyframes fadeIn{from{opacity:0;transform:translateY(7px)}to{opacity:1;transform:translateY(0)}}
  .container{max-width:1100px;margin:0 auto;padding:34px 22px}

  /* ── HERO ── */
  .hero{text-align:center;padding:56px 22px 34px;background:linear-gradient(150deg,#EFF6FF 0%,#F0F7FF 55%,#FEF3C7 100%)}
  .hero-badge{display:inline-block;background:var(--yellow);color:#92400E;font-size:.74rem;font-weight:800;padding:5px 14px;border-radius:50px;margin-bottom:15px;letter-spacing:.06em;text-transform:uppercase}
  .hero h1{font-family:'Fraunces',serif;font-size:clamp(1.9rem,5vw,3.3rem);font-weight:700;line-height:1.15;max-width:660px;margin:0 auto 15px}
  .hero h1 em{font-style:italic;color:var(--brand)}
  .hero p{color:var(--muted);font-size:1.02rem;max-width:490px;margin:0 auto 28px;line-height:1.7}
  .btn-primary{background:var(--brand);color:white;border:none;font-family:'Nunito',sans-serif;font-size:.97rem;font-weight:800;padding:12px 26px;border-radius:50px;cursor:pointer;transition:all .2s;box-shadow:0 4px 16px rgba(59,130,246,.32)}
  .btn-primary:hover{background:var(--brand-dark);transform:translateY(-2px)}
  .subject-chips{display:flex;flex-wrap:wrap;gap:9px;justify-content:center;margin-top:32px}
  .chip{display:flex;align-items:center;gap:5px;padding:7px 15px;border-radius:50px;font-weight:700;font-size:.85rem;cursor:pointer;transition:all .2s}
  .chip:hover{transform:translateY(-2px)}
  .chip.math{background:var(--purple);color:var(--purple-dark)}
  .chip.grammar{background:var(--pink);color:var(--pink-dark)}
  .chip.science{background:var(--green);color:var(--green-dark)}
  .chip.history{background:var(--orange);color:var(--orange-dark)}

  /* ── CARDS ── */
  .card{background:var(--white);border-radius:var(--r);padding:22px;box-shadow:var(--shadow)}
  .card-title{font-size:.82rem;font-weight:800;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:12px;display:flex;align-items:center;gap:6px}
  .helper-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-bottom:18px}
  @media(max-width:700px){.helper-grid{grid-template-columns:1fr}}
  .subject-row{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:11px}
  .sub-btn{padding:5px 11px;border-radius:50px;border:2px solid #E2E8F0;font-family:'Nunito',sans-serif;font-size:.78rem;font-weight:700;cursor:pointer;background:white;transition:all .2s}
  .sub-btn:hover,.sub-btn.sel{border-color:var(--brand);background:var(--brand-light);color:var(--brand)}
  textarea{width:100%;min-height:128px;border:2px solid #E2E8F0;border-radius:14px;padding:11px;font-family:'Nunito',sans-serif;font-size:.91rem;resize:vertical;outline:none;transition:border-color .2s;line-height:1.6}
  textarea:focus{border-color:var(--brand)}
  .solve-btn{width:100%;margin-top:11px;background:var(--brand);color:white;border:none;font-family:'Nunito',sans-serif;font-size:.93rem;font-weight:800;padding:12px;border-radius:14px;cursor:pointer;transition:all .2s;display:flex;align-items:center;justify-content:center;gap:7px}
  .solve-btn:hover{background:var(--brand-dark)}
  .solve-btn:disabled{background:#94A3B8;cursor:not-allowed}

  /* ── ANSWER ── */
  .answer-area{display:none}.answer-area.visible{display:block}
  .step-card{background:var(--brand-light);border-radius:13px;padding:14px 16px;margin-bottom:8px;border-left:4px solid var(--brand);animation:slideIn .3s ease both}
  @keyframes slideIn{from{opacity:0;transform:translateX(-7px)}to{opacity:1;transform:translateX(0)}}
  .step-num{font-size:.68rem;font-weight:900;color:var(--brand);text-transform:uppercase;letter-spacing:.08em;margin-bottom:3px}
  .step-text{font-size:.9rem;line-height:1.65;color:var(--text);font-weight:600}
  .answer-final{background:linear-gradient(135deg,#D1FAE5,#A7F3D0);border-radius:13px;padding:14px 16px;border-left:4px solid var(--green-dark);margin-top:5px;animation:slideIn .3s ease both}
  .answer-label{font-size:.68rem;font-weight:900;color:var(--green-dark);text-transform:uppercase;letter-spacing:.08em;margin-bottom:3px}
  .answer-value{font-size:1rem;font-weight:800;color:var(--text)}

  /* ── LEARNING MODE OVERLAY ── */
  .attempt-box{background:var(--yellow);border-radius:14px;padding:18px;margin-bottom:14px;border:2px solid var(--yellow-dark)}
  .attempt-box h3{font-size:.97rem;font-weight:900;color:#78350F;margin-bottom:6px}
  .attempt-box p{font-size:.86rem;color:#92400E;margin-bottom:12px;line-height:1.6;font-weight:600}
  .attempt-input{width:100%;border:2px solid #FCD34D;border-radius:11px;padding:10px;font-family:'Nunito',sans-serif;font-size:.9rem;background:white;outline:none;margin-bottom:10px}
  .attempt-input:focus{border-color:var(--yellow-dark)}
  .attempt-submit{background:#F59E0B;color:white;border:none;font-family:'Nunito',sans-serif;font-size:.88rem;font-weight:800;padding:9px 20px;border-radius:50px;cursor:pointer;transition:all .2s}
  .attempt-submit:hover{background:#D97706}
  .attempt-skip{background:none;border:none;font-family:'Nunito',sans-serif;font-size:.82rem;font-weight:700;color:#92400E;cursor:pointer;margin-left:10px;text-decoration:underline}

  /* answer lock */
  .answer-locked{background:#F8FAFC;border:2px dashed #CBD5E1;border-radius:13px;padding:16px;text-align:center;color:var(--muted);font-weight:700;font-size:.9rem;margin-top:5px}
  .unlock-btn{margin-top:10px;background:var(--brand);color:white;border:none;font-family:'Nunito',sans-serif;font-size:.84rem;font-weight:800;padding:8px 18px;border-radius:50px;cursor:pointer}

  /* loading/error */
  .loading{display:flex;align-items:center;gap:7px;color:var(--muted);font-weight:700;padding:20px 0}
  .dot{width:7px;height:7px;border-radius:50%;background:var(--brand);animation:bounce 1.2s infinite}
  .dot:nth-child(2){animation-delay:.2s}.dot:nth-child(3){animation-delay:.4s}
  @keyframes bounce{0%,60%,100%{transform:translateY(0)}30%{transform:translateY(-7px)}}
  .error-box{background:var(--red);border:2px solid #FECACA;border-radius:13px;padding:13px;color:var(--red-dark);font-weight:700;font-size:.87rem}

  /* rephrase/quiz btns */
  .action-btns{display:flex;gap:8px;flex-wrap:wrap;margin-top:12px}
  .act-btn{padding:8px 16px;border-radius:50px;border:none;font-family:'Nunito',sans-serif;font-size:.84rem;font-weight:800;cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:5px}
  .act-btn:hover{transform:translateY(-1px)}
  .act-btn.yellow{background:var(--yellow);color:#92400E}
  .act-btn.purple{background:var(--purple);color:var(--purple-dark)}
  .act-btn:disabled{opacity:.5;cursor:not-allowed;transform:none}

  /* quiz */
  .quiz-wrap{margin-top:12px;display:none}.quiz-wrap.show{display:block}
  .quiz-card{background:var(--white);border-radius:var(--r);padding:20px;box-shadow:var(--shadow);border:2px solid var(--purple)}
  .quiz-meta{font-size:.72rem;font-weight:900;color:var(--purple-dark);text-transform:uppercase;letter-spacing:.06em;margin-bottom:7px}
  .quiz-q{font-size:.94rem;font-weight:700;margin-bottom:11px;line-height:1.5}
  .quiz-opts{display:flex;flex-direction:column;gap:7px;margin-bottom:11px}
  .quiz-opt{background:#F8FAFC;border:2px solid #E2E8F0;border-radius:11px;padding:9px 13px;font-family:'Nunito',sans-serif;font-size:.88rem;font-weight:700;cursor:pointer;text-align:left;transition:all .2s}
  .quiz-opt:hover{border-color:var(--brand);background:var(--brand-light)}
  .quiz-opt.correct{border-color:var(--green-dark);background:var(--green);color:var(--green-dark)}
  .quiz-opt.wrong{border-color:var(--red-dark);background:var(--red);color:var(--red-dark)}
  .quiz-fb{font-size:.88rem;font-weight:700;padding:9px 13px;border-radius:11px;margin-bottom:9px;display:none}
  .quiz-fb.show{display:block}
  .quiz-fb.correct{background:var(--green);color:var(--green-dark)}
  .quiz-fb.wrong{background:var(--red);color:var(--red-dark)}
  .next-btn{background:var(--purple);color:var(--purple-dark);border:none;font-family:'Nunito',sans-serif;font-size:.83rem;font-weight:800;padding:8px 17px;border-radius:50px;cursor:pointer;display:none}
  .next-btn.show{display:inline-block}

  /* video links */
  .vid-links{margin-top:13px;padding:13px;background:#F8FAFC;border-radius:13px;border:2px dashed #CBD5E1}
  .vid-links-title{font-size:.72rem;font-weight:900;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px}
  .vid-link{display:flex;align-items:center;gap:8px;padding:6px 0;border-bottom:1px solid #F1F5F9;text-decoration:none;color:var(--text);transition:color .2s;font-size:.87rem}
  .vid-link:last-child{border-bottom:none}
  .vid-link:hover{color:var(--brand)}
  .vid-icon{width:30px;height:30px;background:var(--red-dark);border-radius:7px;display:flex;align-items:center;justify-content:center;color:white;font-size:.85rem;flex-shrink:0}
  .vid-info{flex:1}
  .vid-title{font-weight:800;display:block;font-size:.87rem}
  .vid-meta{font-size:.73rem;color:var(--muted);font-weight:600}

  /* ── PROGRESS ── */
  .skill-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(185px,1fr));gap:13px}
  .skill-card{background:var(--white);border-radius:var(--r);padding:19px;box-shadow:var(--shadow)}
  .skill-icon{font-size:1.6rem;margin-bottom:7px}
  .skill-name{font-weight:800;font-size:.88rem;margin-bottom:8px}
  .prog-bar{background:#E2E8F0;border-radius:50px;height:8px;overflow:hidden;margin-bottom:4px}
  .prog-fill{height:100%;border-radius:50px;transition:width 1.2s ease}
  .skill-pct{font-size:.75rem;font-weight:700;color:var(--muted)}
  .plan-grid{display:grid;grid-template-columns:1fr 1fr;gap:15px}
  @media(max-width:700px){.plan-grid{grid-template-columns:1fr}}
  .plan-card{background:var(--white);border-radius:var(--r);padding:19px;box-shadow:var(--shadow)}
  .plan-week{font-size:.68rem;font-weight:900;text-transform:uppercase;letter-spacing:.08em;margin-bottom:5px}
  .plan-card h3{font-size:.94rem;font-weight:800;margin-bottom:8px}
  .plan-tasks{list-style:none}
  .plan-tasks li{display:flex;align-items:flex-start;gap:7px;padding:5px 0;font-size:.85rem;color:var(--muted);font-weight:600;border-bottom:1px solid #F1F5F9}
  .plan-tasks li:last-child{border-bottom:none}
  .task-chk{width:16px;height:16px;border-radius:50%;border:2px solid #CBD5E1;flex-shrink:0;margin-top:1px;cursor:pointer;transition:all .2s;display:flex;align-items:center;justify-content:center;font-size:.62rem}
  .task-chk.done{background:var(--green-dark);border-color:var(--green-dark);color:white}
  .ai-box{background:var(--white);border-radius:var(--r);padding:22px;box-shadow:var(--shadow);margin-top:26px}
  .ai-content{font-size:.91rem;line-height:1.8;color:var(--text);white-space:pre-wrap;font-weight:600}

  /* ── PRINT REPORT ── */
  .report-btn{background:var(--green-dark);color:white;border:none;font-family:'Nunito',sans-serif;font-size:.88rem;font-weight:800;padding:10px 20px;border-radius:50px;cursor:pointer;display:flex;align-items:center;gap:6px;transition:all .2s}
  .report-btn:hover{background:#047857}
  @media print{
    nav,#print-btn,.report-btn,.act-btn,.solve-btn,.sub-btn,.subject-row,#page-home,#page-helper,#page-videos,#page-dashboard{display:none!important}
    #page-progress{display:block!important}
    body{background:white}
    .card,.skill-card,.plan-card,.ai-box{box-shadow:none;border:1px solid #E2E8F0}
    .print-header{display:block!important}
  }
  .print-header{display:none;text-align:center;padding:20px 0 14px;border-bottom:2px solid #E2E8F0;margin-bottom:20px}
  .print-header h1{font-family:'Fraunces',serif;font-size:1.6rem;margin-bottom:4px}
  .print-header p{color:var(--muted);font-size:.88rem}

  /* ── TEACHER DASHBOARD ── */
  .teacher-gate{background:var(--white);border-radius:var(--r);padding:32px;box-shadow:var(--shadow);max-width:420px;margin:60px auto;text-align:center}
  .teacher-gate h2{font-family:'Fraunces',serif;font-size:1.6rem;margin-bottom:8px}
  .teacher-gate p{color:var(--muted);margin-bottom:20px;font-size:.92rem;line-height:1.6;font-weight:600}
  .pin-input{width:100%;border:2px solid #E2E8F0;border-radius:14px;padding:12px;font-family:'Nunito',sans-serif;font-size:1.2rem;text-align:center;letter-spacing:.3em;outline:none;margin-bottom:12px;font-weight:800}
  .pin-input:focus{border-color:var(--brand)}
  .pin-hint{font-size:.78rem;color:var(--muted);margin-bottom:14px;font-weight:600}

  /* teacher content */
  .t-section{display:none}.t-section.show{display:block}
  .t-stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:13px;margin-bottom:24px}
  .t-stat{background:var(--white);border-radius:var(--r);padding:17px;box-shadow:var(--shadow);text-align:center}
  .t-stat-num{font-size:1.8rem;font-weight:900;margin-bottom:3px}
  .t-stat-lbl{font-size:.72rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.05em}
  .t-table{width:100%;border-collapse:collapse;font-size:.87rem}
  .t-table th{text-align:left;padding:10px 12px;background:#F8FAFC;font-size:.72rem;font-weight:900;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;border-bottom:2px solid #E2E8F0}
  .t-table td{padding:10px 12px;border-bottom:1px solid #F1F5F9;font-weight:600;vertical-align:top}
  .t-table tr:last-child td{border-bottom:none}
  .subj-tag{display:inline-block;padding:2px 9px;border-radius:50px;font-size:.72rem;font-weight:800}

  /* ── SCHOOL CUSTOMIZER ── */
  .customizer{background:var(--white);border-radius:var(--r);padding:24px;box-shadow:var(--shadow);margin-bottom:22px}
  .custom-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:14px}
  @media(max-width:600px){.custom-grid{grid-template-columns:1fr}}
  .field-label{font-size:.78rem;font-weight:800;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:5px}
  .field-input{width:100%;border:2px solid #E2E8F0;border-radius:11px;padding:9px 12px;font-family:'Nunito',sans-serif;font-size:.9rem;font-weight:700;outline:none;transition:border-color .2s}
  .field-input:focus{border-color:var(--brand)}
  .color-row{display:flex;gap:10px;align-items:center;margin-top:5px}
  .color-swatch{width:30px;height:30px;border-radius:50%;cursor:pointer;border:3px solid transparent;transition:all .2s;flex-shrink:0}
  .color-swatch.active{border-color:var(--text);transform:scale(1.15)}
  .apply-btn{background:var(--brand);color:white;border:none;font-family:'Nunito',sans-serif;font-size:.88rem;font-weight:800;padding:10px 22px;border-radius:50px;cursor:pointer;margin-top:14px;transition:all .2s}
  .apply-btn:hover{background:var(--brand-dark)}
  .preview-bar{border-radius:12px;padding:13px 18px;margin-top:14px;display:flex;align-items:center;gap:10px;font-weight:800}

  /* ── VIDEOS ── */
  .vid-filter{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:20px}
  .flt-btn{padding:5px 14px;border-radius:50px;border:2px solid #E2E8F0;font-family:'Nunito',sans-serif;font-size:.8rem;font-weight:700;cursor:pointer;background:white;transition:all .2s}
  .flt-btn:hover,.flt-btn.active{border-color:var(--brand);background:var(--brand-light);color:var(--brand)}
  .vid-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(230px,1fr));gap:15px}
  .vid-card{background:var(--white);border-radius:var(--r);overflow:hidden;box-shadow:var(--shadow);transition:transform .2s;cursor:pointer;text-decoration:none;color:var(--text);display:block}
  .vid-card:hover{transform:translateY(-4px)}
  .vid-thumb{height:115px;display:flex;align-items:center;justify-content:center;font-size:2.4rem;position:relative}
  .play-btn{position:absolute;width:38px;height:38px;background:rgba(255,255,255,.92);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.9rem;box-shadow:0 2px 9px rgba(0,0,0,.12);padding-left:3px}
  .vid-info{padding:12px}
  .vid-subj{font-size:.65rem;font-weight:900;text-transform:uppercase;letter-spacing:.07em;margin-bottom:2px}
  .vid-ttl{font-size:.88rem;font-weight:800;margin-bottom:3px;line-height:1.3}
  .vid-ch{font-size:.74rem;color:var(--muted);font-weight:600}

  /* ── DASHBOARD ── */
  .stats-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(138px,1fr));gap:12px;margin-bottom:22px}
  .stat-card{background:var(--white);border-radius:var(--r);padding:16px;box-shadow:var(--shadow);text-align:center}
  .stat-num{font-size:1.75rem;font-weight:900;margin-bottom:2px}
  .stat-lbl{font-size:.7rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.05em}
  .rec-list{list-style:none}
  .rec-item{display:flex;align-items:center;gap:11px;padding:11px 0;border-bottom:1px solid #F1F5F9}
  .rec-item:last-child{border-bottom:none}
  .rec-icon{width:38px;height:38px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.05rem;flex-shrink:0}
  .rec-info{flex:1}
  .rec-title{font-weight:800;font-size:.88rem}
  .rec-sub{font-size:.74rem;color:var(--muted);font-weight:600}

  /* section head */
  .sec-head{margin-bottom:20px}
  .sec-head h2{font-family:'Fraunces',serif;font-size:1.7rem;margin-bottom:3px}
  .sec-head p{color:var(--muted);font-size:.93rem}
  .feature-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(205px,1fr));gap:15px}
  .toast{position:fixed;bottom:24px;right:24px;background:var(--text);color:white;padding:11px 20px;border-radius:50px;font-size:.86rem;font-weight:800;z-index:999;opacity:0;transform:translateY(10px);transition:all .3s;pointer-events:none}
  .toast.show{opacity:1;transform:translateY(0)}
</style>
</head>
<body>

<!-- ══ NAV ══ -->
