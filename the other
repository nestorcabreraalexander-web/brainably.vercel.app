async function fetchExplanation(attempt=''){
  setBusy(true);
  const detectedLang = detectQuestionLang(curQ);
  const sys = buildSystemPrompt('explain', detectedLang);
  const usr = attempt
    ? `The student's question: "${curQ}"\n\nThe student attempted this answer first: "${attempt}"\n\nBriefly acknowledge their attempt in Step 1 (tell them if they were right, close, or what they missed), then give the full step-by-step explanation.`
    : `Question: ${curQ}`;

  try {
    // Run Claude and Wolfram in parallel — Wolfram never blocks Claude
    const wolframPromise = (subject === 'Math' || subject === 'Engineering') && isMathQuestion(curQ)
      ? callWolfram(curQ)
      : Promise.resolve(null);

    const ans = await callAI(sys, usr, 1200);
    curAns = ans;
    setBusy(false);
    document.getElementById('ans-content').innerHTML = fmtAnswer(ans);
    document.getElementById('ans-area').classList.add('show');
