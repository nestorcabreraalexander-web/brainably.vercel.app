// Step header patterns for all 6 languages + generic numbered formats
const STEP_RX = /^(Step\s*\d+|Étape\s*\d+|Paso\s*\d+|第\s*\d+\s*步|الخطوة\s*\d+|Passo\s*\d+|\d+[\.\)]\s+\w)/i;
// Answer line patterns for all 6 languages
const ANS_RX  = /^(✅\s*)?(Answer|Final Answer|Key Takeaway|Réponse|Réponse finale|Respuesta|Respuesta final|答案|最终答案|الإجابة|الإجابة النهائية|Resposta|Resposta final)\s*[:–—]/i;

function fmtAnswer(rawText){
  // ── 1. Extract and protect code blocks BEFORE splitting into lines ──
  const codeBlocks = [];
  let text = rawText.replace(/```([\w+-]*)[ \t]*\n?([\s\S]*?)```/g, (_, lang, code) => {
    const idx = codeBlocks.length;
    codeBlocks.push({ lang: lang||'code', code: code.trim() });
    return `\n@@CODE_${idx}@@\n`;
  });

  const lines = text.split('\n');
  let html = '', stepTitle = '', stepBody = [];

  function flushStep(){
    if(!stepTitle) return;
    // Render any inline code blocks inside the step body
    const bodyHtml = stepBody
      .map(l => {
        const cm = l.match(/^@@CODE_(\d+)@@$/);
        if(cm){
          const cb = codeBlocks[+cm[1]];
          return `<span class="code-lang-tag">${escHtml(cb.lang)}</span><div class="code-block">${escHtml(cb.code)}</div>`;
        }
        return l ? escHtml(l) : '<br>';
      })
      .filter(l => l !== '<br>' || stepBody.length > 1) // don't start with blank
      .join('<br>');
    html += `<div class="step-card"><div class="step-num">${escHtml(stepTitle)}</div><div class="step-text">${bodyHtml}</div></div>`;
    stepTitle = ''; stepBody = [];
  }

  for(const rawLine of lines){
    const tr = rawLine.trim();

    // ── Standalone code block placeholder ──
    if(/^@@CODE_\d+@@$/.test(tr)){
      const idx = +tr.match(/\d+/)[0];
      const cb = codeBlocks[idx];
      if(stepTitle){
        stepBody.push(tr); // belongs to current step
      } else {
        html += `<span class="code-lang-tag">${escHtml(cb.lang)}</span><div class="code-block">${escHtml(cb.code)}</div>`;
      }
      continue;
    }

    // ── Empty line ──
    if(!tr){
      if(stepTitle) stepBody.push('');
      continue;
    }

    // ── ✅ Answer line ──
    if(ANS_RX.test(tr) || /^✅\s+\S/.test(tr)){
      flushStep();
      const val = tr
        .replace(/^✅\s*/,'')
        .replace(ANS_RX,'')
        .replace(/^[:–—\s]+/,'')
        .trim();
      html += `<div class="ans-final"><div class="ans-label">✅ Answer</div><div class="ans-value">${escHtml(val || tr)}</div></div>`;
      continue;
    }

    // ── Step header ──
    if(STEP_RX.test(tr)){
      flushStep();
      stepTitle = tr;
      continue;
    }

    // ── Regular content ──
    if(stepTitle){
      stepBody.push(tr);
    } else {
      // Pre-step text (like a brief intro sentence) — render as paragraph
      html += `<p style="margin-bottom:7px;line-height:1.75;font-size:.89rem;font-weight:600">${escHtml(tr)}</p>`;
    }
  }

  flushStep(); // flush any remaining step

  // ── Fallback: if nothing parsed correctly, render as clean readable text ──
  if(!html){
    html = `<div class="step-card"><div class="step-num">Response</div><div class="step-text" style="white-space:pre-wrap">${escHtml(rawText.trim())}</div></div>`;
  }

  // ── If we got steps but no ✅ Answer line, extract last sentence as answer ──
  if(html && !html.includes('ans-final')){
    const sentences = rawText.replace(/\n+/g,' ').split(/(?<=[.!?])\s+/);
    const lastSentence = sentences.filter(s=>s.trim().length>10).pop()||'';
    if(lastSentence) html += `<div class="ans-final"><div class="ans-label">✅ Answer</div><div class="ans-value">${escHtml(lastSentence.trim())}</div></div>`;
  }

  return html;
}

function escHtml(s){
  if(typeof s !== 'string') return '';
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

