<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>StudyBuddy – AI Homework Helper</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Fraunces:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
<style>
  :root {
    --brand:#3B82F6;--brand-dark:#1D4ED8;--brand-light:#EFF6FF;
    --yellow:#FDE68A;--yellow-dark:#F59E0B;
    --green:#D1FAE5;--green-dark:#059669;
    --pink:#FCE7F3;--pink-dark:#DB2777;
    --purple:#EDE9FE;--purple-dark:#7C3AED;
    --orange:#FFEDD5;--orange-dark:#EA580C;
    --teal:#CFFAFE;--teal-dark:#0891B2;
    --red:#FEE2E2;--red-dark:#DC2626;
    --indigo:#E0E7FF;--indigo-dark:#4338CA;
    --lime:#ECFCCB;--lime-dark:#65A30D;
    --bg:#F0F7FF;--text:#1E293B;--muted:#64748B;
    --white:#fff;--shadow:0 4px 20px rgba(59,130,246,.1);--r:18px;
  }
  *{margin:0;padding:0;box-sizing:border-box}
  body{font-family:'Nunito',sans-serif;background:var(--bg);color:var(--text);min-height:100vh}

  /* ── NAV ── */
  nav{background:var(--white);padding:10px 20px;display:flex;align-items:center;justify-content:space-between;box-shadow:0 2px 10px rgba(0,0,0,.06);position:sticky;top:0;z-index:300;flex-wrap:wrap;gap:8px}
  .logo{font-size:1.35rem;font-weight:900;color:var(--brand);display:flex;align-items:center;gap:6px;cursor:pointer;white-space:nowrap}
  .school-tag{font-size:.72rem;font-weight:800;color:var(--muted);margin-left:3px}
  nav ul{list-style:none;display:flex;gap:2px;flex-wrap:wrap}
  nav ul li button{background:none;border:none;font-family:'Nunito',sans-serif;font-size:.83rem;font-weight:700;color:var(--muted);cursor:pointer;padding:6px 11px;border-radius:50px;transition:all .2s;white-space:nowrap}
  nav ul li button:hover,nav ul li button.active{background:var(--brand-light);color:var(--brand)}
  .nav-right{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
  .nav-sel{border:2px solid #E2E8F0;border-radius:50px;padding:4px 9px;font-family:'Nunito',sans-serif;font-size:.78rem;font-weight:700;outline:none;cursor:pointer;background:white;transition:border-color .2s}
  .nav-sel:focus{border-color:var(--brand)}
  .lm-wrap{display:flex;align-items:center;gap:6px;font-size:.76rem;font-weight:800;color:var(--muted)}
  .tog{width:36px;height:19px;background:#CBD5E1;border-radius:50px;cursor:pointer;position:relative;transition:background .25s;flex-shrink:0}
  .tog.on{background:var(--green-dark)}
  .tog::after{content:'';width:15px;height:15px;background:white;border-radius:50%;position:absolute;top:2px;left:2px;transition:left .25s;box-shadow:0 1px 3px rgba(0,0,0,.2)}
  .tog.on::after{left:19px}

  /* ── PAGES ── */
  .page{display:none;animation:fadeIn .3s ease}.page.active{display:block}
  @keyframes fadeIn{from{opacity:0;transform:translateY(7px)}to{opacity:1;transform:translateY(0)}}
  .container{max-width:1100px;margin:0 auto;padding:32px 20px}

  /* ── HERO ── */
  .hero{text-align:center;padding:52px 20px 32px;background:linear-gradient(150deg,#EFF6FF 0%,#F0F7FF 55%,#FEF3C7 100%)}
  .hero-badge{display:inline-block;background:var(--yellow);color:#92400E;font-size:.72rem;font-weight:800;padding:4px 13px;border-radius:50px;margin-bottom:14px;letter-spacing:.06em;text-transform:uppercase}
  .hero h1{font-family:'Fraunces',serif;font-size:clamp(1.8rem,5vw,3.2rem);font-weight:700;line-height:1.15;max-width:640px;margin:0 auto 14px}
  .hero h1 em{font-style:italic;color:var(--brand)}
  .hero p{color:var(--muted);font-size:1rem;max-width:480px;margin:0 auto 26px;line-height:1.7}
  .btn-primary{background:var(--brand);color:white;border:none;font-family:'Nunito',sans-serif;font-size:.95rem;font-weight:800;padding:12px 26px;border-radius:50px;cursor:pointer;transition:all .2s;box-shadow:0 4px 14px rgba(59,130,246,.3)}
  .btn-primary:hover{background:var(--brand-dark);transform:translateY(-2px)}

  /* subject chips */
  .chips{display:flex;flex-wrap:wrap;gap:7px;justify-content:center;margin-top:28px}
  .chip{display:flex;align-items:center;gap:5px;padding:6px 13px;border-radius:50px;font-weight:700;font-size:.82rem;cursor:pointer;transition:all .2s;white-space:nowrap}
  .chip:hover{transform:translateY(-2px)}
  .c-math{background:var(--purple);color:var(--purple-dark)}
  .c-grammar{background:var(--pink);color:var(--pink-dark)}
  .c-science{background:var(--green);color:var(--green-dark)}
  .c-history{background:var(--orange);color:var(--orange-dark)}
  .c-code{background:var(--teal);color:var(--teal-dark)}
  .c-eng{background:var(--lime);color:var(--lime-dark)}
  .c-lang{background:var(--indigo);color:var(--indigo-dark)}

  /* ── CARDS ── */
  .card{background:var(--white);border-radius:var(--r);padding:20px;box-shadow:var(--shadow)}
  .card-title{font-size:.8rem;font-weight:800;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:11px;display:flex;align-items:center;gap:6px}
  .grid2{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px}
  @media(max-width:700px){.grid2{grid-template-columns:1fr}}

  /* subject selector */
  .subj-row{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:10px}
  .sb{padding:4px 10px;border-radius:50px;border:2px solid #E2E8F0;font-family:'Nunito',sans-serif;font-size:.76rem;font-weight:700;cursor:pointer;background:white;transition:all .2s;white-space:nowrap}
  .sb:hover,.sb.sel{border-color:var(--brand);background:var(--brand-light);color:var(--brand)}

  /* coding sub-selector */
  .code-sub{display:none;flex-wrap:wrap;gap:5px;margin-bottom:8px}
  .code-sub.show{display:flex}
  .csb{padding:3px 9px;border-radius:50px;border:2px solid var(--teal-dark);font-family:'Nunito',sans-serif;font-size:.73rem;font-weight:700;cursor:pointer;background:var(--teal);color:var(--teal-dark);transition:all .2s}
  .csb:hover,.csb.sel{background:var(--teal-dark);color:white}

  /* engineering sub-selector */
  .eng-sub{display:none;flex-wrap:wrap;gap:5px;margin-bottom:8px}
  .eng-sub.show{display:flex}
  .esb{padding:3px 9px;border-radius:50px;border:2px solid var(--lime-dark);font-family:'Nunito',sans-serif;font-size:.73rem;font-weight:700;cursor:pointer;background:var(--lime);color:var(--lime-dark);transition:all .2s}
  .esb:hover,.esb.sel{background:var(--lime-dark);color:white}

  textarea{width:100%;min-height:120px;border:2px solid #E2E8F0;border-radius:13px;padding:11px;font-family:'Nunito',sans-serif;font-size:.9rem;resize:vertical;outline:none;transition:border-color .2s;line-height:1.6}
  textarea:focus{border-color:var(--brand)}
  .solve-btn{width:100%;margin-top:10px;background:var(--brand);color:white;border:none;font-family:'Nunito',sans-serif;font-size:.92rem;font-weight:800;padding:12px;border-radius:13px;cursor:pointer;transition:all .2s;display:flex;align-items:center;justify-content:center;gap:7px}
  .solve-btn:hover{background:var(--brand-dark)}
  .solve-btn:disabled{background:#94A3B8;cursor:not-allowed}

  /* answer */
  .ans-area{display:none}.ans-area.show{display:block}
  .step-card{background:var(--brand-light);border-radius:12px;padding:13px 15px;margin-bottom:8px;border-left:4px solid var(--brand);animation:slideIn .3s ease both}
  @keyframes slideIn{from{opacity:0;transform:translateX(-7px)}to{opacity:1;transform:translateX(0)}}
  .step-num{font-size:.67rem;font-weight:900;color:var(--brand);text-transform:uppercase;letter-spacing:.08em;margin-bottom:3px}
  .step-text{font-size:.89rem;line-height:1.65;font-weight:600}

  /* code block styling */
  .code-block{background:#1E293B;border-radius:11px;padding:13px 15px;margin:8px 0;font-family:monospace;font-size:.84rem;line-height:1.6;color:#E2E8F0;overflow-x:auto;white-space:pre-wrap}
  .code-block .kw{color:#93C5FD}
  .code-block .str{color:#86EFAC}
  .code-block .cm{color:#6B7280;font-style:italic}
  .code-lang-tag{display:inline-block;background:var(--teal-dark);color:white;font-size:.68rem;font-weight:800;padding:2px 8px;border-radius:50px;margin-bottom:6px;text-transform:uppercase;letter-spacing:.05em}

  .ans-final{background:linear-gradient(135deg,#D1FAE5,#A7F3D0);border-radius:12px;padding:13px 15px;border-left:4px solid var(--green-dark);margin-top:5px;animation:slideIn .3s ease both}
  .ans-label{font-size:.67rem;font-weight:900;color:var(--green-dark);text-transform:uppercase;letter-spacing:.08em;margin-bottom:3px}
  .ans-value{font-size:.98rem;font-weight:800}

  .loading{display:flex;align-items:center;gap:7px;color:var(--muted);font-weight:700;padding:20px 0}
  .dot{width:7px;height:7px;border-radius:50%;background:var(--brand);animation:bounce 1.2s infinite}
  .dot:nth-child(2){animation-delay:.2s}.dot:nth-child(3){animation-delay:.4s}
  @keyframes bounce{0%,60%,100%{transform:translateY(0)}30%{transform:translateY(-7px)}}
  .err-box{background:var(--red);border:2px solid #FECACA;border-radius:12px;padding:12px;color:var(--red-dark);font-weight:700;font-size:.86rem}

  /* attempt box */
  .attempt-box{background:var(--yellow);border-radius:13px;padding:16px;margin-bottom:13px;border:2px solid var(--yellow-dark)}
  .attempt-box h3{font-size:.94rem;font-weight:900;color:#78350F;margin-bottom:5px}
  .attempt-box p{font-size:.84rem;color:#92400E;margin-bottom:10px;line-height:1.6;font-weight:600}
  .attempt-inp{width:100%;border:2px solid #FCD34D;border-radius:10px;padding:9px;font-family:'Nunito',sans-serif;font-size:.88rem;background:white;outline:none;margin-bottom:9px}
  .attempt-inp:focus{border-color:var(--yellow-dark)}
  .attempt-sub{background:#F59E0B;color:white;border:none;font-family:'Nunito',sans-serif;font-size:.86rem;font-weight:800;padding:8px 18px;border-radius:50px;cursor:pointer}
  .attempt-skip{background:none;border:none;font-family:'Nunito',sans-serif;font-size:.8rem;font-weight:700;color:#92400E;cursor:pointer;margin-left:9px;text-decoration:underline}

  /* ans locked */
  .ans-locked{background:#F8FAFC;border:2px dashed #CBD5E1;border-radius:12px;padding:14px;text-align:center;color:var(--muted);font-weight:700;font-size:.88rem;margin-top:5px}
  .unlock-btn{margin-top:9px;background:var(--brand);color:white;border:none;font-family:'Nunito',sans-serif;font-size:.82rem;font-weight:800;padding:7px 16px;border-radius:50px;cursor:pointer}

  /* action btns */
  .act-btns{display:flex;gap:7px;flex-wrap:wrap;margin-top:11px}
  .act-btn{padding:7px 14px;border-radius:50px;border:none;font-family:'Nunito',sans-serif;font-size:.81rem;font-weight:800;cursor:pointer;transition:all .2s}
  .act-btn:hover{transform:translateY(-1px)}
  .act-btn:disabled{opacity:.5;cursor:not-allowed;transform:none}
  .ab-yellow{background:var(--yellow);color:#92400E}
  .ab-purple{background:var(--purple);color:var(--purple-dark)}

  /* vid links */
  .vid-links{margin-top:12px;padding:12px;background:#F8FAFC;border-radius:12px;border:2px dashed #CBD5E1}
  .vlt{font-size:.7rem;font-weight:900;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:7px}
  .vl{display:flex;align-items:center;gap:7px;padding:5px 0;border-bottom:1px solid #F1F5F9;text-decoration:none;color:var(--text);font-size:.85rem;transition:color .2s}
  .vl:last-child{border-bottom:none}
  .vl:hover{color:var(--brand)}
  .vi{width:28px;height:28px;background:var(--red-dark);border-radius:6px;display:flex;align-items:center;justify-content:center;color:white;font-size:.82rem;flex-shrink:0}
  .vt{font-weight:800;display:block;font-size:.85rem}
  .vm{font-size:.72rem;color:var(--muted);font-weight:600}

  /* quiz */
  .quiz-wrap{margin-top:11px;display:none}.quiz-wrap.show{display:block}
  .quiz-card{background:var(--white);border-radius:var(--r);padding:18px;border:2px solid var(--purple)}
  .quiz-meta{font-size:.7rem;font-weight:900;color:var(--purple-dark);text-transform:uppercase;letter-spacing:.06em;margin-bottom:6px}
  .quiz-q{font-size:.92rem;font-weight:700;margin-bottom:10px;line-height:1.5}
  .quiz-opts{display:flex;flex-direction:column;gap:6px;margin-bottom:10px}
  .qopt{background:#F8FAFC;border:2px solid #E2E8F0;border-radius:10px;padding:8px 12px;font-family:'Nunito',sans-serif;font-size:.86rem;font-weight:700;cursor:pointer;text-align:left;transition:all .2s}
  .qopt:hover{border-color:var(--brand);background:var(--brand-light)}
  .qopt.correct{border-color:var(--green-dark);background:var(--green);color:var(--green-dark)}
  .qopt.wrong{border-color:var(--red-dark);background:var(--red);color:var(--red-dark)}
  .qfb{font-size:.86rem;font-weight:700;padding:8px 12px;border-radius:10px;margin-bottom:8px;display:none}
  .qfb.show{display:block}
  .qfb.correct{background:var(--green);color:var(--green-dark)}
  .qfb.wrong{background:var(--red);color:var(--red-dark)}
  .nxt-btn{background:var(--purple);color:var(--purple-dark);border:none;font-family:'Nunito',sans-serif;font-size:.81rem;font-weight:800;padding:7px 15px;border-radius:50px;cursor:pointer;display:none}
  .nxt-btn.show{display:inline-block}

  /* ── PROGRESS ── */
  .skill-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(175px,1fr));gap:12px}
  .sk-card{background:var(--white);border-radius:var(--r);padding:18px;box-shadow:var(--shadow)}
  .sk-icon{font-size:1.5rem;margin-bottom:6px}
  .sk-name{font-weight:800;font-size:.86rem;margin-bottom:8px}
  .pb{background:#E2E8F0;border-radius:50px;height:7px;overflow:hidden;margin-bottom:4px}
  .pf{height:100%;border-radius:50px;transition:width 1.2s ease}
  .sk-pct{font-size:.73rem;font-weight:700;color:var(--muted)}
  .plan-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px}
  @media(max-width:700px){.plan-grid{grid-template-columns:1fr}}
  .plan-card{background:var(--white);border-radius:var(--r);padding:18px;box-shadow:var(--shadow)}
  .pw{font-size:.67rem;font-weight:900;text-transform:uppercase;letter-spacing:.08em;margin-bottom:4px}
  .plan-card h3{font-size:.92rem;font-weight:800;margin-bottom:8px}
  .pt-list{list-style:none}
  .pt-list li{display:flex;align-items:flex-start;gap:6px;padding:4px 0;font-size:.83rem;color:var(--muted);font-weight:600;border-bottom:1px solid #F1F5F9}
  .pt-list li:last-child{border-bottom:none}
  .tchk{width:15px;height:15px;border-radius:50%;border:2px solid #CBD5E1;flex-shrink:0;margin-top:1px;cursor:pointer;transition:all .2s;display:flex;align-items:center;justify-content:center;font-size:.6rem}
  .tchk.done{background:var(--green-dark);border-color:var(--green-dark);color:white}
  .ai-box{background:var(--white);border-radius:var(--r);padding:20px;box-shadow:var(--shadow);margin-top:24px}
  .ai-txt{font-size:.9rem;line-height:1.8;white-space:pre-wrap;font-weight:600}

  /* print */
  .rpt-btn{background:var(--green-dark);color:white;border:none;font-family:'Nunito',sans-serif;font-size:.85rem;font-weight:800;padding:9px 18px;border-radius:50px;cursor:pointer;transition:all .2s}
  .rpt-btn:hover{background:#047857}
  @media print{nav,.rpt-btn,.act-btns,.solve-btn,.sb,#page-home,#page-helper,#page-videos,#page-dashboard,#page-teacher,#page-school{display:none!important}#page-progress{display:block!important}body{background:white}.print-hdr{display:block!important}}
  .print-hdr{display:none;text-align:center;padding:16px 0 12px;border-bottom:2px solid #E2E8F0;margin-bottom:16px}

  /* ── VIDEOS ── */
  .vid-filter{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:18px}
  .fb{padding:5px 13px;border-radius:50px;border:2px solid #E2E8F0;font-family:'Nunito',sans-serif;font-size:.78rem;font-weight:700;cursor:pointer;background:white;transition:all .2s}
  .fb:hover,.fb.active{border-color:var(--brand);background:var(--brand-light);color:var(--brand)}
  .vid-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(225px,1fr));gap:14px}
  .vc{background:var(--white);border-radius:var(--r);overflow:hidden;box-shadow:var(--shadow);transition:transform .2s;cursor:pointer;text-decoration:none;color:var(--text);display:block}
  .vc:hover{transform:translateY(-4px)}
  .vthumb{height:110px;display:flex;align-items:center;justify-content:center;font-size:2.3rem;position:relative}
  .play{position:absolute;width:36px;height:36px;background:rgba(255,255,255,.9);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.88rem;box-shadow:0 2px 8px rgba(0,0,0,.1);padding-left:2px}
  .vi2{padding:11px}
  .vs{font-size:.64rem;font-weight:900;text-transform:uppercase;letter-spacing:.07em;margin-bottom:2px}
  .vtt{font-size:.87rem;font-weight:800;margin-bottom:3px;line-height:1.3}
  .vch{font-size:.73rem;color:var(--muted);font-weight:600}

  /* ── DASHBOARD ── */
  .stats-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:11px;margin-bottom:20px}
  .stat-card{background:var(--white);border-radius:var(--r);padding:15px;box-shadow:var(--shadow);text-align:center}
  .stat-n{font-size:1.7rem;font-weight:900;margin-bottom:2px}
  .stat-l{font-size:.69rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.05em}
  .rec-list{list-style:none}
  .rec-item{display:flex;align-items:center;gap:10px;padding:10px 0;border-bottom:1px solid #F1F5F9}
  .rec-item:last-child{border-bottom:none}
  .rec-ico{width:36px;height:36px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0}
  .rec-inf{flex:1}
  .rec-ttl{font-weight:800;font-size:.87rem}
  .rec-sub{font-size:.72rem;color:var(--muted);font-weight:600}

  /* ── TEACHER ── */
  .teacher-gate{background:var(--white);border-radius:var(--r);padding:28px;box-shadow:var(--shadow);max-width:400px;margin:50px auto;text-align:center}
  .teacher-gate h2{font-family:'Fraunces',serif;font-size:1.5rem;margin-bottom:7px}
  .teacher-gate p{color:var(--muted);margin-bottom:18px;font-size:.9rem;line-height:1.6;font-weight:600}
  .pin-inp{width:100%;border:2px solid #E2E8F0;border-radius:13px;padding:11px;font-family:'Nunito',sans-serif;font-size:1.2rem;text-align:center;letter-spacing:.3em;outline:none;margin-bottom:10px;font-weight:800}
  .pin-inp:focus{border-color:var(--brand)}
  .pin-hint{font-size:.76rem;color:var(--muted);font-weight:600}
  .t-sec{display:none}.t-sec.show{display:block}
  .t-stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:11px;margin-bottom:20px}
  .t-stat{background:var(--white);border-radius:var(--r);padding:15px;box-shadow:var(--shadow);text-align:center}
  .t-sn{font-size:1.7rem;font-weight:900;margin-bottom:2px}
  .t-sl{font-size:.69rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.05em}
  .t-tbl{width:100%;border-collapse:collapse;font-size:.85rem}
  .t-tbl th{text-align:left;padding:9px 11px;background:#F8FAFC;font-size:.7rem;font-weight:900;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;border-bottom:2px solid #E2E8F0}
  .t-tbl td{padding:9px 11px;border-bottom:1px solid #F1F5F9;font-weight:600;vertical-align:top}
  .t-tbl tr:last-child td{border-bottom:none}
  .stag{display:inline-block;padding:2px 8px;border-radius:50px;font-size:.7rem;font-weight:800}

  /* ── SCHOOL SETUP ── */
  .custom-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:12px}
  @media(max-width:600px){.custom-grid{grid-template-columns:1fr}}
  .fl{font-size:.76rem;font-weight:800;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:4px}
  .fi{width:100%;border:2px solid #E2E8F0;border-radius:10px;padding:8px 11px;font-family:'Nunito',sans-serif;font-size:.88rem;font-weight:700;outline:none;transition:border-color .2s}
  .fi:focus{border-color:var(--brand)}
  .color-row{display:flex;gap:9px;align-items:center;margin-top:4px}
  .cswatch{width:28px;height:28px;border-radius:50%;cursor:pointer;border:3px solid transparent;transition:all .2s;flex-shrink:0}
  .cswatch.active{border-color:var(--text);transform:scale(1.15)}
