// ══ OpenRouter API — FREE, works directly in browser, no server, no proxy needed ══
// Free tier: 50 requests/day without account, 1000/day with free account
// Sign up at openrouter.ai — no credit card ever required
function getApiKey(){ return localStorage.getItem('sb_openrouter_key')||''; }

async function callAI(sys, usr, maxTok=1000){
  const key = getApiKey();
  if(!key) throw new Error('No API key — go to the Setup tab and paste your free OpenRouter key.');

  const r = await fetch('https://openrouter.ai/api/v1/chat/completions', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'Authorization': `Bearer ${key}`,
      'HTTP-Referer': 'https://studybuddy.app',
      'X-Title': 'StudyBuddy'
    },
    body: JSON.stringify({
      model: 'meta-llama/llama-4-maverick:free',
      max_tokens: maxTok,
      temperature: 0.4,
      messages: [
        { role: 'system', content: sys },
        { role: 'user',   content: usr }
      ]
    })
  });

  if(!r.ok){
    const e = await r.json().catch(()=>({}));
    if(r.status===401) throw new Error('Invalid API key. Double-check your key in the Setup tab.');
    if(r.status===429) throw new Error('Free limit reached for today. Try again tomorrow or sign up for more.');
    throw new Error(e.error?.message || `Error ${r.status}`);
  }

  const d = await r.json();
  return d.choices?.[0]?.message?.content || '';
}

// ══════════ SOLVE ══════════
async function solveQ(){
  let q = document.getElementById('q-inp').value.trim();
  if(!q){ document.getElementById('q-inp').focus(); return; }

  // ── Smart input cleanup ──
  q = q.replace(/\bwat\b/gi,'What').replace(/\bwuts\b/gi,'What is').replace(/\bplz\b/gi,'Please').replace(/\bu\b/gi,'you').replace(/\br\b/gi,'are').replace(/\bidk\b/gi,'I do not know').replace(/\bbtw\b/gi,'by the way');
  // Convert number-x-number → multiply (but NOT algebra like 3x+7)
  q = q.replace(/(\d+)\s*[xX]\s*(\d+)/g, '$1 × $2');
  // Convert * and / everywhere in math expressions
  q = q.replace(/(\d|\))\s*\*\s*(\d|\()/g, '$1 × $2');
  q = q.replace(/(\d+)\s*\/\s*(\d+)/g, '$1 ÷ $2');
  // If the entire input is just a math expression (e.g. "1+1", "246 × 126", "5-3", "(5+3)×2")
  // wrap it so the AI knows exactly what to do — and do this BEFORE adding a question mark
  if(/^[\d\s\+\-×÷\*\/\(\)\.,%\^=\?]+$/.test(q.trim())){
    q = 'Calculate and show your work: ' + q.trim().replace(/\?$/,'');
  }
  // Add question mark only if it looks like a question sentence — not a math expression or topic word
  if(/^(what|how|why|when|where|who|is|are|can|do|does|explain|define|solve|find|write|create|qué|cómo|cuál|dónde|por|qu'est|comment|pourquoi)/i.test(q) && !q.startsWith('Calculate') && !q.endsWith('?') && !q.endsWith('.')){
    q += '?';
  }
  document.getElementById('q-inp').value = q;
  curQ = q;

  // ── Show language detection hint ──
  const detected = detectQuestionLang(q);
  const uiLang = getLangName();
  if(detected && detected !== uiLang){
    toast(`🌐 Question detected in ${detected} — answering in ${detected}!`);
  }

  if(learningMode && ansMode!=='always'){
    document.getElementById('empty-st').style.display='none';
    document.getElementById('err-st').style.display='none';
    document.getElementById('ans-area').classList.remove('show');
    document.getElementById('attempt-wrap').style.display='block';
    document.getElementById('attempt-inp').value='';
    document.getElementById('attempt-inp').focus();
    return;
  }
  await fetchExplanation();
}

