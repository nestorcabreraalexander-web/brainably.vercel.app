function detectQuestionLang(q){
  // Spanish indicators
  if(/[áéíóúüñ¿¡]/i.test(q) || /\b(qué|cómo|cuál|cuándo|dónde|por qué|qué es|cuadrada|cuadrado|área|triángulo|círculo|resolver|explicar|suma|resta|multiplicar|dividir|raíz|ecuación|fracción|promedio|perimetro|perímetro)\b/i.test(q)) return 'Spanish';
  // French indicators
  if(/[àâäéèêëîïôùûüÿœæç]/i.test(q) || /\b(qu'est|comment|pourquoi|quelle|carré|aire|triangle|cercle|résoudre|expliquer|somme|racine|équation|fraction|moyenne)\b/i.test(q)) return 'French';
  // Arabic indicators
  if(/[\u0600-\u06FF]/.test(q)) return 'Arabic';
  // Chinese indicators
  if(/[\u4E00-\u9FFF]/.test(q)) return 'Mandarin Chinese';
  // Portuguese indicators
  if(/[ãõâêîôûáéíóú]/i.test(q) && /\b(área|quadrado|triângulo|círculo|resolver|explicar|soma|raiz|equação|fração|média|equação)\b/i.test(q)) return 'Portuguese';
  return null;
}

