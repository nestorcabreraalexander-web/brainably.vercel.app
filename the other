async function rephrase(){
  if(!curQ) return;
  const btn = document.getElementById('solve-btn');
  btn.disabled = true;
  const detectedLang = detectQuestionLang(curQ);
  const sys = buildSystemPrompt('rephrase', detectedLang);
  const usr = `The student did not understand this explanation: "${curQ}"\n\nPrevious answer summary: ${curAns.slice(0,300)}\n\nNow explain it a completely different way.`;
  try {
    const ans = await callAI(sys, usr, 1200);
    curAns = ans;
    document.getElementById('ans-content').innerHTML =
      `<div style="background:var(--yellow);border-radius:10px;padding:8px 12px;margin-bottom:10px;font-size:.8rem;font-weight:800;color:#92400E">🔁 ${t('rephrase_btn')} — different approach!</div>`
      + fmtAnswer(ans);
    if(ansMode==='hide'){ document.querySelectorAll('.ans-final').forEach(e=>e.style.display='none'); }
  } catch(e){ toast('⚠️ '+e.message); }
  btn.disabled = false;
}

// ══════════ QUIZ ══════════
async function startQuiz(){
  const qw=document.getElementById('quiz-wrap'); qw.classList.add('show');
  const ql=document.getElementById('qload'); ql.style.display='flex';
  document.getElementById('qbody').innerHTML='';
  const langName = getLangName();
  const sys = `You are a quiz generator. You MUST respond with ONLY a valid JSON object — no explanation, no markdown, no backticks, no extra text whatsoever.
The JSON must follow this exact schema:
{"questions":[{"q":"question text","options":["option A","option B","option C","option D"],"answer":0,"explanation":"why the correct answer is right"}]}
Rules:
- Exactly 3 questions
- answer is the 0-based index of the correct option (0=A, 1=B, 2=C, 3=D)
- All text in ${langName}
- Questions should test understanding of the concept, not just memory of words
- Make wrong options plausible (common mistakes) not obviously silly
- Keep language appropriate for ${getGrade()}`;

  const usr = `Create a 3-question quiz about this topic.
Topic: ${curQ}
Key content to test: ${curAns.replace(/```[\s\S]*?```/g,'[code example]').slice(0,700)}`;

  try {
    let raw = await callAI(sys, usr, 800);
    // Aggressively clean the response — strip any wrapper text
    raw = raw.trim();
    // Find the first { and last } to extract just the JSON
    const start = raw.indexOf('{');
    const end = raw.lastIndexOf('}');
    if(start === -1 || end === -1) throw new Error('No JSON found in response');
    raw = raw.slice(start, end+1);
    quizData = JSON.parse(raw);
    // Validate structure
    if(!quizData.questions || !Array.isArray(quizData.questions) || quizData.questions.length === 0){
      throw new Error('Invalid quiz structure');
    }
    // Clamp answer index just in case
    quizData.questions.forEach(q => {
      q.answer = Math.max(0, Math.min(3, q.answer||0));
      if(!q.options || q.options.length < 2) q.options = ['True','False','Maybe','Not sure'];
    });
    quizIdx=0; ql.style.display='none'; renderQuizQ();
    if(history[0]){ history[0].quizTaken=true; localStorage.setItem('sb_history',JSON.stringify(history.slice(0,40))); }
    if(ansMode==='hide'){ document.querySelectorAll('.ans-final').forEach(e=>e.style.display='block'); document.getElementById('ans-locked').style.display='none'; }
  } catch(e){
    ql.style.display='none';
    document.getElementById('qbody').innerHTML=`<div class="err-box">⚠️ Couldn't generate quiz — try again. (${escHtml(e.message)})</div><button class="act-btn ab-purple" onclick="startQuiz()" style="margin-top:8px">🔄 Retry Quiz</button>`;
  }
}
function renderQuizQ(){
  const qb=document.getElementById('qbody');
  if(!quizData||quizIdx>=quizData.questions.length){
    qb.innerHTML=`<div style="text-align:center;padding:12px 0"><div style="font-size:1.7rem;margin-bottom:5px">🎉</div><div style="font-weight:800">${t('quick_quiz')} ✓</div></div>`; return;
  }
  const q=quizData.questions[quizIdx];
  qb.innerHTML=`<div style="font-size:.68rem;font-weight:800;color:var(--muted);margin-bottom:5px">${quizIdx+1}/${quizData.questions.length}</div>
    <div class="quiz-q">${q.q}</div>
    <div class="quiz-opts">${q.options.map((o,i)=>`<button class="qopt" onclick="ansQ(${i})">${o}</button>`).join('')}</div>
    <div class="qfb" id="qfb"></div>
    <button class="nxt-btn" id="nxt-btn" onclick="nextQ()">${quizIdx+1<quizData.questions.length?'Next →':'Finish ✓'}</button>`;
}
function ansQ(c){
  const q=quizData.questions[quizIdx];
  document.querySelectorAll('.qopt').forEach(o=>o.disabled=true);
  document.querySelectorAll('.qopt')[q.answer].classList.add('correct');
  if(c!==q.answer) document.querySelectorAll('.qopt')[c].classList.add('wrong');
  const fb=document.getElementById('qfb');
  fb.className='qfb show '+(c===q.answer?'correct':'wrong');
  fb.textContent=c===q.answer?`✅ ${q.explanation}`:`❌ ${q.options[q.answer]} — ${q.explanation}`;
  document.getElementById('nxt-btn').classList.add('show');
}
function nextQ(){ quizIdx++; renderQuizQ(); }

