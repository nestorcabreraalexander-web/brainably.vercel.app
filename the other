// Detect if a question is math/science that Wolfram can verify
function isMathQuestion(q){
  // Bare calculation expressions
  if(/^Calculate and show your work:/i.test(q)) return true;
  // Contains operators with numbers
  if(/\d+\s*[\+\-×÷\*\/\^]\s*\d+/.test(q)) return true;
  // Common math keywords
  if(/\b(solve|calculate|compute|evaluate|simplify|factor|derivative|integral|equation|formula|average|mean|median|percent|percentage|square root|sqrt|hypotenuse|area|perimeter|volume|circumference|convert|how many|how much|how far|speed|distance|time|weight|temperature|fahrenheit|celsius|inches|meters|kilograms|pounds)\b/i.test(q)) return true;
  return false;
}

// Extract just the math expression for Wolfram (strip "Calculate and show your work:" prefix etc.)
function extractMathQuery(q){
  return q
    .replace(/^Calculate and show your work:\s*/i, '')
    .replace(/^(what is|solve|calculate|compute|find|evaluate)\s+/i, '')
    .replace(/\?$/, '')
    .trim();
}

// Call Wolfram Alpha Short Answers API via a CORS proxy
// Returns { result, source } or null if unavailable
async function callWolfram(query){
  const appId = localStorage.getItem('sb_wolfram_key') || 'DEMO';
  const q = encodeURIComponent(extractMathQuery(query));

  // Use allorigins as a CORS proxy (free, no setup needed for demo)
  // In production, the user should enter their own App ID
  const proxyUrl = `https://api.allorigins.win/raw?url=${encodeURIComponent(`https://api.wolframalpha.com/v1/result?appid=${appId}&i=${q}&units=metric`)}`;

  try {
    const resp = await Promise.race([
      fetch(proxyUrl),
      new Promise((_, rej) => setTimeout(() => rej(new Error('timeout')), 5000))
    ]);
    if(!resp.ok) return null;
    const text = (await resp.text()).trim();
    // Wolfram returns "Wolfram|Alpha did not understand your input" or error strings for failures
    if(!text || text.includes('did not understand') || text.includes('No short answer') || text.length > 200) return null;
    return { result: text, source: 'Wolfram Alpha' };
  } catch(e){
    return null; // Silently fail — never break the main experience
  }
}

